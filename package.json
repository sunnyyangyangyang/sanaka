{
  "name": "sanaka",
  "productName": "Sanaka",
  "version": "0.0.2-beta",
  "description": "Sanaka desktop frontend",
  "main": "main.js",
  "scripts": {
    "start": "npm run build && node ./scripts/start-electron.js",
    "build": "tsc --noEmit && vite build",
    "dev:ui": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:mac": "bash ./scripts/package-sanaka-macos.sh /Volumes/sks/src/qemu-11.0.1/build-sanaka",
    "pack:win": "npx electron-builder --win",
    "pack:win:dir": "bash ./scripts/package-sanaka-windows.sh",
    "pack:linux": "npx electron-builder --linux"
  },
  "keywords": [
    "electron",
    "qemu",
    "virtual-machine",
    "sanaka"
  ],
  "author": "Sanakaprix",
  "license": "GPL-2.0-or-later",
  "build": {
    "appId": "com.sanakaprix.sanaka",
    "asar": true,
    "afterPack": "build/after-pack.js",
    "electronDist": "node_modules/electron/dist",
    "extraResources": [
      "testnet.iso"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "runtime/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "fileAssociations": [
        {
          "ext": "saka",
          "name": "SanakaMachinePackage",
          "description": "Sanaka Virtual Machine",
          "icon": "build/sanakafishpackage-document.icns",
          "isPackage": true,
          "role": "Viewer"
        }
      ],
      "target": [
        "dir"
      ]
    },
    "dmg": {
      "background": "build/dmg.png",
      "iconSize": 100,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 190,
          "type": "file"
        },
        {
          "x": 410,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "assets/icons/sanakafish.png",
      "fileAssociations": [
        {
          "ext": "svm",
          "name": "SanakaMachineConfig",
          "description": "Sanaka Virtual Machine Configuration",
          "icon": "build/sanakafishpackage-document.ico"
        }
      ],
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "perMachine": true,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "assets/icons/sanakafish.png",
      "target": [
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Sanakaprix",
      "synopsis": "Sanaka virtual machine frontend",
      "description": "Sanaka is an Electron-based QEMU virtual machine frontend with built-in noVNC console integration.",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional",
      "afterInstall": "build/deb-after-install.sh",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0",
        "qemu-system",
        "qemu-utils"
      ],
      "recommends": [
        "ovmf",
        "qemu-block-extra",
        "samba"
      ]
    }
  },
  "dependencies": {
    "@novnc/novnc": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "smol-toml": "^1.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^38.2.2",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
